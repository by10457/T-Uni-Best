# 变量必须以 VITE_ 为前缀才能暴露给外部读取
NODE_ENV = 'production'
# 是否去除console 和 debugger
VITE_DELETE_CONSOLE = true
# 是否开启sourcemap
VITE_SHOW_SOURCEMAP = false

# 后台请求地址（生产环境使用 Nginx 反向代理，所以使用相对路径）
VITE_SERVER_BASEURL = 'https://mp.sisanjiu.com'

# h5是否需要配置代理（生产环境不需要，由 Nginx 处理）
VITE_APP_PROXY_ENABLE = false

# 第二个请求地址
VITE_SERVER_BASEURL_SECONDARY = 'https://mp.sisanjiu.com'

# 认证模式
VITE_AUTH_MODE = 'double'